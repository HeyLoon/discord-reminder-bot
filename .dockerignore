# Dependencies (will be installed fresh in container)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (CRITICAL - contains secrets)
.env
.env.*
!.env.example
!.env.docker

# Runtime data files (user-specific, will be in volume)
*.json
!package.json
!package-lock.json

# Git files
.git
.gitignore
.gitattributes

# Documentation (keep only README.md)
*.md
!README.md
!README-DOCKER.md

# IDE/Editor files
.vscode
.idea
*.swp
*.swo
*~
.editorconfig

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Test files
test/
tests/
*.test.js
*.spec.js
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# CI/CD files (not needed in image)
.github/
.gitlab-ci.yml
.travis.yml

# Docker files (not needed in image)
docker-compose*.yml
Dockerfile*
